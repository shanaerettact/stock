{
  "name": "stock-trading-stats",
  "version": "1.0.0",
  "description": "股票交易統計分析系統 - 專業的交易記錄與績效分析平台",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:init": "tsx prisma/init-account.ts",
    "db:update-capital": "tsx prisma/update-capital.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next node_modules/.cache",
    "stocks:import": "tsx scripts/import-stocks.ts",
    "stocks:guide": "tsx scripts/fetch-twse-stocks.ts",
    "stocks:update": "tsx scripts/fetch-twse-stocks.ts"
  },
  "keywords": [
    "stock",
    "trading",
    "statistics",
    "portfolio",
    "finance",
    "taiwan-stock",
    "nextjs",
    "prisma"
  ],
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "lightweight-charts": "^5.1.0",
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "prisma": "^5.9.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
